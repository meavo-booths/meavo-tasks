# Copy to .env.local and fill in — never commit real values.

# Shared Neon Postgres (same database as meavo-gateway)
DATABASE_URL=

# NextAuth v5 — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Optional: invite-only Google sign-in
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Tool-card gate (defaults to seed-tasks-tool if unset)
TASKS_TOOL_CARD_ID=seed-tasks-tool

# @meavo/navigation tool switcher
MEAVO_APP_KEY=tasks
GATEWAY_URL=https://meavo.app

# Bearer secret for /api/cron/* routes
CRON_SECRET=

# Optional: org-wide Slack digest webhook + digest timezone
SLACK_TASK_DIGEST_WEBHOOK_URL=
TASK_DIGEST_TIMEZONE=Europe/Sofia
